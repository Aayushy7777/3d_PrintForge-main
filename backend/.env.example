# ─── Server ──────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_optional

# ─── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=your_strong_random_jwt_secret

# ─── Razorpay (optional) ──────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ─── CORS ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Optional (only if using email features) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
STORE_NAME=PrintForge

# ─── Optional (scripts/migrations) ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/postgres?schema=public
